# ==========================================
# SEODrift Environment Configuration
# ==========================================

# 1. Database (Neon.tech)
DB_URL=jdbc:postgresql://your-neon-hostname.neon.tech/seoDB?sslmode=require
DB_USER=your_username
DB_PASSWORD=your_password

# 2. Google OAuth2 (Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# 3. App Keys & URLs
YT_API_KEY=your-youtube-data-api-v3-key
BASE_URL=https://www.googleapis.com/youtube/v3
APP_URL=https://seodrift-xyz.a.run.app

# 4. Redis Configuration (Aiven) 
REDIS_HOST=your-redis-hostname.aivencloud.com
REDIS_PORT=your-redis-port
REDIS_PASSWORD=your_redis_password
REDIS_SSL_ENABLED=true

# 5. Spring Configuration
SPRING_PROFILES_ACTIVE=dev
PORT=8080
